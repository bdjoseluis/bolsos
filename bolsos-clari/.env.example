# ============================================================
#  .env.example — copia a .env y rellena los valores reales
#  NUNCA subas .env a git (ya está en .gitignore)
# ============================================================

# ── Postgres (Spring Boot) ───────────────────────────────────
POSTGRES_DB=bolsosdb
POSTGRES_USER=bolsos_user
POSTGRES_PASSWORD=CAMBIA_ESTA_CONTRASEÑA

# ── Postgres (Odoo) ──────────────────────────────────────────
ODOO_DB_USER=odoo_user
ODOO_DB_PASSWORD=CAMBIA_ESTA_CONTRASEÑA

# ── Postgres (Windmill) ──────────────────────────────────────
WINDMILL_DB_NAME=windmill
WINDMILL_DB_USER=windmill_user
WINDMILL_DB_PASSWORD=CAMBIA_ESTA_CONTRASEÑA
